TELEGRAM_TOKEN=your_telegram_token_here
ADMIN_ID=your_telegram_id_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# PostgreSQL credentials
POSTGRES_DB=emet_bot
POSTGRES_USER=emet
POSTGRES_PASSWORD=change_me_strong_password

# Database URL (використовується контейнерами)
DATABASE_URL=postgresql://emet:POSTGRES_PASSWORD@localhost:5432/emet_bot

# LMS: ID папки Google Drive з курсами
COURSE_FOLDER_ID=
SYNC_INTERVAL_SEC=3600

# Google Drive sync
AUTO_SYNC_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# Quality Monitor
MONITOR_HOURS=24

# Timezone
TZ=Europe/Kyiv

# Admin Panel
ADMIN_PASSWORD=change_me
FLASK_SECRET=change_me_random_string
